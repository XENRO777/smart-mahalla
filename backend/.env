# ═══════════════════════════════════════════
# SmartMahalla Backend — Environment Variables
# ═══════════════════════════════════════════

PORT=8000

# JWT secret for signing auth tokens
JWT_SECRET=smart-mahalla-dev-secret-key-change-in-production

# ─── Supabase (optional, only if you need direct DB access) ───
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ─── AI Provider (OpenAI-compatible API) ───
# Used by /api/v1/ai/chat when not using Python subprocess.
# Leave empty to use the Python fallback (child_process spawn).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Python path (for AI subprocess) ───
PYTHON_PATH=python
